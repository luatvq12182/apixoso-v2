# Copy file này thành .env rồi điền giá trị thực

# Môi trường: development | production
# Dev: static HTML (public/) được serve để test UI
# Production: static HTML bị tắt (docker-compose tự set NODE_ENV=production)
NODE_ENV=development

# MongoDB credentials (dùng trong docker-compose)
MONGO_USER=kqxs
MONGO_PASS=changeme_strong_password

# Port expose ra ngoài VPS (đổi nếu đã dùng cổng này)
HOST_PORT=3083

# Nếu chạy npm start trực tiếp (không qua Docker), dùng URI này thay thế
# MONGO_URI=mongodb://kqxs:changeme@localhost:27017/kqxs?authSource=admin
