    },
    {
      "name": "Live",
      "item": [
        {
          "name": "GET live - miền Nam",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/live/mn?since=0",
              "host": ["{{base_url}}"],
              "path": ["live", "mn"],
              "query": [{ "key": "since", "value": "0", "description": "Unix timestamp ms — 0 = lấy ngay" }]
            }
          }
        },
        {
          "name": "GET live - miền Trung",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/live/mt?since=0",
              "host": ["{{base_url}}"],
              "path": ["live", "mt"],
              "query": [{ "key": "since", "value": "0" }]
            }
          }
        },
        {
          "name": "GET live - miền Bắc",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/live/mb?since=0",
              "host": ["{{base_url}}"],
              "path": ["live", "mb"],
              "query": [{ "key": "since", "value": "0" }]
            }
          }
        }
      ]
    }
  ]
}
