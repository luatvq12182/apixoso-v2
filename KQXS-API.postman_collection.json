              "path": ["stats", "lo-gan"],
              "query": [{ "key": "region", "value": "mb" }]
            }
          }
        },
        {
          "name": "GET lô gan - miền Nam",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/stats/lo-gan?region=south&days=180",
              "host": ["{{base_url}}"],
              "path": ["stats", "lo-gan"],
              "query": [
                { "key": "region", "value": "south" },
                { "key": "days",   "value": "180" }
              ]
            }
          }
        },
        {
          "name": "GET đề tần suất - MB 30 ngày",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/stats/de-tan-suat?region=mb&days=30",
              "host": ["{{base_url}}"],
              "path": ["stats", "de-tan-suat"],
              "query": [
                { "key": "region", "value": "mb" },
                { "key": "days",   "value": "30" }
              ]
            }
          }
        },
        {
          "name": "GET đề tần suất - tỉnh XSHCM",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/stats/de-tan-suat?province=XSHCM&days=90",
              "host": ["{{base_url}}"],
              "path": ["stats", "de-tan-suat"],
              "query": [
                { "key": "province", "value": "XSHCM" },
                { "key": "days",     "value": "90" }
              ]
            }
          }
        },
        {
          "name": "GET đề gan - MB",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/stats/de-gan?region=mb",
              "host": ["{{base_url}}"],
              "path": ["stats", "de-gan"],
              "query": [{ "key": "region", "value": "mb" }]
            }
          }
        },
        {
          "name": "GET đề gan - miền Nam",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/stats/de-gan?region=south",
